# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real secrets.

# ── GitHub Webhook Integration ─────────────────────────────────────────────────

# The secret string you enter when creating the webhook on GitHub.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
GITHUB_SECRET=your_webhook_secret_here

# A GitHub Personal Access Token.
# Required scopes: Contents (read), Pull requests (read + write)
# Create one at: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_your_token_here

# ── AI Models (optional overrides) ────────────────────────────────────────────
# Uncomment to override the defaults in config.py

# CODE_REVIEW_MODEL=deepseek-coder:1.3b
# BUG_FIX_MODEL=deepseek-coder:1.3b
# TEST_GEN_MODEL=deepseek-coder:1.3b
# PLANNING_MODEL=llama3.2:1b
